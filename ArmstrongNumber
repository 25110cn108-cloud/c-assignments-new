#include <iostream>
using namespace std;
bool isArmstrong(int n) {
    int original = n;
    int sum = 0;
    while (n > 0) {
        int digit = n % 10;
        sum += digit * digit * digit; // For 3-digit numbers
        n /= 10;
    }
    return original == sum;
}
int main() {
    int num = 153;
    if (isArmstrong(num)) 
        cout << num << " is an Armstrong Number" << endl;
    else
        cout << num << " is not an Armstrong Number" << endl;
    return 0;
}