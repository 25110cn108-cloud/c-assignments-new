#include <iostream>
using namespace std;
bool isPrime(int n) {
    if (n <= 1) return false;
    for (int i = 2; i <= n / 2; i++) {
        if (n % i == 0) return false;
    }
    return true;
}
int factorial(int n) {
    if (n == 0 || n == 1) return 1;
    return n * factorial(n - 1);
}
int main() {
    int num = 5;
    if (isPrime(num)) 
    cout << num << " is a Prime Number" << endl;
    else
    cout << num << " is not a Prime Number" << endl;

    int fact = factorial(num);
    cout << "The factorial of " << num << " is: " << fact << endl;
    return 0;
}
